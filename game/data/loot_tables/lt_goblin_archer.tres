[gd_resource type="Resource" script_class="LootTableData" format=3]

[ext_resource type="Script" path="res://game/scripts/data/LootTableData.gd" id="1_loot_table_script"]
[ext_resource type="Script" path="res://game/scripts/data/LootEntryData.gd" id="2_loot_entry_script"]
[ext_resource type="Resource" path="res://game/data/items/material_arrowhead.tres" id="3_arrowhead_item"]
[ext_resource type="Resource" path="res://game/data/items/material_bowstring.tres" id="4_bowstring_item"]

[sub_resource type="Resource" id="1_arrowhead_entry"]
script = ExtResource("2_loot_entry_script")
item_data = ExtResource("3_arrowhead_item")
min_amount = 1
max_amount = 3
drop_chance = 0.85

[sub_resource type="Resource" id="2_bowstring_entry"]
script = ExtResource("2_loot_entry_script")
item_data = ExtResource("4_bowstring_item")
drop_chance = 0.45

[resource]
script = ExtResource("1_loot_table_script")
loot_entries = Array[ExtResource("2_loot_entry_script")]([SubResource("1_arrowhead_entry"), SubResource("2_bowstring_entry")])
